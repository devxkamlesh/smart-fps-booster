{
  "schemaVersion": 1,
  "id": "smartfpsbooster",
  "version": "${version}",
  "name": "Smart FPS Booster",
  "description": "Intelligent auto-optimization mod that configures Minecraft settings based on your hardware and gameplay style.",
  "authors": ["devxkamlesh"],
  "contact": {
    "homepage": "https://modrinth.com/user/devxkamlesh",
    "sources": "https://github.com/devxkamlesh/smart-fps-booster",
    "issues": "https://github.com/devxkamlesh/smart-fps-booster/issues"
  },
  "license": "MIT",
  "icon": "assets/smartfpsbooster/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": ["com.smartclient.fpsbooster.SmartFPSBoosterClient"],
    "modmenu": ["com.smartclient.fpsbooster.compat.ModMenuIntegration"]
  },
  "mixins": ["smartfpsbooster.mixins.json"],
  "depends": {
    "fabricloader": ">=0.16.0",
    "minecraft": "~1.21.8",
    "java": ">=21",
    "fabric-api": "*"
  },
  "suggests": {
    "sodium": "*",
    "iris": "*",
    "lithium": "*",
    "modmenu": "*"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.donate": "https://www.buymeacoffee.com/devxkamlesh"
      }
    }
  }
}
